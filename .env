AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin1234
MINIO_BUCKET=mlflow-artifacts

# Evidently — fsspec env vars for MinIO-backed workspace
FSSPEC_S3_ENDPOINT_URL=http://localhost:9000
FSSPEC_S3_KEY=minioadmin
FSSPEC_S3_SECRET=minioadmin1234

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
